{
  "name": "vibe-code-tours",
  "version": "0.3.0",
  "description": "Vibe Code Tours bootcamp toolkit — student + instructor CLI.",
  "homepage": "https://vibecode.tours",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vibe-code-tours/cli.git"
  },
  "license": "MIT",
  "bin": {
    "vibe-code-tours": "./bin/vibe-code-tours.mjs"
  },
  "type": "module",
  "files": [
    "bin",
    "lib",
    "scripts",
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node --test 'tests/*.test.mjs'",
    "embed": "node scripts/build-embed.mjs",
    "build": "npm run embed && esbuild bin/vibe-code-tours.mjs --bundle --platform=node --target=node22 --format=esm --minify --outfile=dist/cli.mjs",
    "prepack": "npm run build",
    "release:dryrun": "npm pack --dry-run"
  },
  "keywords": [
    "vibecode",
    "bootcamp",
    "claude",
    "myanmar",
    "ai-coding"
  ],
  "author": "Vibe Code Tours <ai@vibecode.tours>",
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
